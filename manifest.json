{
  "manifest_version": 3,
  "name": "NetFilter",
  "description": "Bad Websites Blocker",
  "version": "1.0.0",
  "icons": {
    "16": "img/logo16.png",
    "48": "img/logo48.png",
    "128": "img/logo128.png"
  },
  "action": {
    "default_icon": {
      "16": "img/logo16.png",
      "48": "img/logo48.png",
      "128": "img/logo128.png"
    },
    "default_title": "NetFilter Dashboard"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "options_page": "sidepanel.html",
  "background": {
    "service_worker": "background.js"
  }
}